{
  "name": "cc-buddy",
  "version": "3.2.3",
  "description": "🎰 Interactive pet reroller for Claude Code /buddy. Pick species, rarity, eyes, hat, shiny — guided step by step. EN/中文. (AST patch inspired by https://linux.do/t/topic/1916229/10)",
  "type": "module",
  "bin": {
    "cc-buddy": "./dist/buddy-reroll.mjs"
  },
  "scripts": {
    "build": "esbuild buddy-reroll.mjs --bundle --platform=node --format=esm --outfile=dist/buddy-reroll.mjs",
    "prepublishOnly": "npm run build",
    "start": "node buddy-reroll.mjs",
    "search": "node buddy-reroll.mjs search",
    "check": "node buddy-reroll.mjs check",
    "gallery": "node buddy-reroll.mjs gallery",
    "selftest": "node buddy-reroll.mjs selftest"
  },
  "keywords": [
    "claude",
    "claude-code",
    "buddy",
    "pet",
    "reroll",
    "companion",
    "anthropic"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fengshao1227/cc-buddy.git"
  },
  "dependencies": {
    "acorn": "^8.16.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
